#!/usr/bin/env lua

local root = os.getenv("RIEMA_ROOT")
if not root or root == "" then
  local script = arg[0] or "./riema"
  root = script:match("^(.*)[/\\][^/\\]+$") or "."
end

package.path = table.concat({
  root .. "/lua/?.lua",
  root .. "/lua/?/init.lua",
  package.path,
}, ";")

local cli = require("riema.cli")
os.exit(cli.main(arg))
